# ─────────────────────────────────────────────────────────────
# 로컬 개발용 환경변수 템플릿
#
# 사용법: 이 파일을 복사해서 .env 를 만들고 값을 채우세요.
#     Windows: copy .env.example .env
#     bash   : cp .env.example .env
#
# ⚠️ .env 는 .gitignore 로 제외되어 GitHub에 올라가지 않습니다.
# ⚠️ 실제 키를 이 파일(.env.example)에는 절대 넣지 마세요 — 이 파일은 커밋됩니다.
# ─────────────────────────────────────────────────────────────

# OpenAI API 키 — AI 분석 챗봇(/api/chat) 서버 프록시에서만 사용.
# 브라우저로는 절대 전달되지 않습니다.
OPENAI_API_KEY=

# (선택) 사용할 OpenAI 모델. 미설정 시 gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini

# (선택) 로컬 서버 포트. 미설정 시 3000
# PORT=3000

# ─────────────────────────────────────────────────────────────
# 참고 1) Firebase 웹 설정(apiKey/authDomain/projectId 등)은 "비밀이 아니며"
#         브라우저가 직접 읽어야 하므로 .env가 아니라
#         test1/public/firebase-config.js 에 그대로 둡니다.
#         (보안은 Firebase Auth + Firestore Security Rules가 담당)
#
# 참고 2) Vercel 배포 환경에서는 .env 파일을 쓰지 않습니다.
#         Vercel → 프로젝트 → Settings → Environment Variables 에 등록하세요.
#
# 참고 3) 키 우선순위:
#         실제 환경변수 > test1/.env > 루트 .env > test1/.openai-key(구방식 폴백)
# ─────────────────────────────────────────────────────────────
